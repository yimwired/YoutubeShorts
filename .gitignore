# Secrets
.env
token_youtube.json
token_tiktok.json
client_secrets.json

# Video output (large files) -- but keep A/B candidate thumbnails:
# swap_thumbnails.py runs on GitHub Actions days after generation and
# needs thumb_*_b.jpg present in the repo (prune_thumbs.py bounds growth).
output/*
!output/thumb_*_b.jpg
*.mp4
*.mp3
*.wav

